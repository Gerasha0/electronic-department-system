@startuml Electronic_Department_System_Simple

title Electronic Department System - Architecture

package "Entities" {
    class User {
        -Long id
        -String username
        -String password
        -String email
        -String firstName
        -String lastName
        -UserRole role
        -Boolean isActive
    }

    class Student {
        -Long id
        -User user
        -String studentNumber
        -Integer enrollmentYear
        -StudentGroup group
        -String phoneNumber
        -String address
    }

    class Teacher {
        -Long id
        -User user
        -String academicTitle
        -String scientificDegree
        -String departmentPosition
        -String phoneNumber
        -String officeNumber
    }

    class Subject {
        -Long id
        -String subjectName
        -String subjectCode
        -String description
        -Integer credits
        -Integer semester
        -Integer hoursTotal
    }

    class StudentGroup {
        -Long id
        -String groupName
        -Integer courseYear
        -String specialization
        -Integer startYear
        -Integer maxStudents
    }

    class Grade {
        -Long id
        -Student student
        -Teacher teacher
        -Subject subject
        -Integer gradeValue
        -String gradeType
        -String comments
        -Boolean isFinal
    }

    enum UserRole {
        ADMIN
        MANAGER
        TEACHER
        STUDENT
        GUEST
    }

    enum StudyForm {
        FULL_TIME
        PART_TIME
        EVENING
        DISTANCE
    }

    enum AssessmentType {
        EXAM
        CREDIT
        DIFFERENTIATED_CREDIT
        COURSE_WORK
        COURSE_PROJECT
    }

    enum GradeType {
        CURRENT
        MODULE
        MIDTERM
        FINAL
        RETAKE
        MAKEUP
    }
}

package "Services" {
    class UserService {
        -UnitOfWork unitOfWork
        +findAll()
        +findById()
        +create()
        +update()
        +delete()
    }

    class StudentService {
        -UnitOfWork unitOfWork
        +findAll()
        +findByGroup()
        +create()
        +update()
    }

    class TeacherService {
        -UnitOfWork unitOfWork
        +findActiveTeachers()
        +findById()
        +create()
        +assignSubject()
    }

    class SubjectService {
        -UnitOfWork unitOfWork
        +findAll()
        +findByCode()
        +create()
        +update()
    }

    class GradeService {
        -UnitOfWork unitOfWork
        +findByStudent()
        +createGrade()
        +updateGrade()
        +calculateAverage()
    }
}

package "Controllers" {
    class UserController {
        -UserService userService
        +getAllUsers()
        +getUserById()
        +createUser()
        +updateUser()
        +deleteUser()
    }

    class PublicController {
        -TeacherService teacherService
        -SubjectService subjectService
        +getAllTeachers()
        +getTeacherById()
        +getAllSubjects()
    }

    class GradeController {
        -GradeService gradeService
        +getStudentGrades()
        +createGrade()
        +updateGrade()
    }
}

package "Data Access" {
    interface UserRepository {
        +findByUsername(String)
        +findByEmail(String)
        +findByRole(UserRole)
    }

    interface StudentRepository {
        +findByStudentNumber(String)
        +findByGroup(StudentGroup)
        +findByEnrollmentYear(Integer)
    }

    interface TeacherRepository {
        +findByUsername(String)
        +findByDepartmentPosition(String)
        +findActiveTeachers()
    }

    interface SubjectRepository {
        +findBySubjectCode(String)
        +findBySemester(Integer)
        +findByCredits(Integer)
    }

    interface StudentGroupRepository {
        +findByGroupName(String)
        +findByCourseYear(Integer)
        +findBySpecialization(String)
    }

    interface GradeRepository {
        +findByStudent(Student)
        +findBySubject(Subject)
        +findByTeacher(Teacher)
        +findByGradeType(GradeType)
    }

    class UnitOfWork {
        -UserRepository userRepository
        -StudentRepository studentRepository
        -TeacherRepository teacherRepository
        -SubjectRepository subjectRepository
        -StudentGroupRepository studentGroupRepository
        -GradeRepository gradeRepository
        +getUserRepository()
        +getStudentRepository()
        +getTeacherRepository()
        +getSubjectRepository()
        +getStudentGroupRepository()
        +getGradeRepository()
    }
}

package "DTOs" {
    class UserDto {
        -Long id
        -String username
        -String email
        -String firstName
        -String lastName
        -UserRole role
    }

    class StudentDto {
        -Long id
        -String studentNumber
        -String firstName
        -String lastName
        -String groupName
        -Integer enrollmentYear
    }

    class TeacherDto {
        -Long id
        -String firstName
        -String lastName
        -String academicTitle
        -String departmentPosition
        -List<String> subjects
    }

    class SubjectDto {
        -Long id
        -String subjectName
        -String subjectCode
        -Integer credits
        -Integer semester
        -String assessmentType
    }

    class GradeDto {
        -Long id
        -String studentName
        -String subjectName
        -String teacherName
        -Integer gradeValue
        -String gradeType
        -LocalDateTime gradeDate
        -String comments
    }
}

package "Configuration" {
    class SecurityConfig {
        +passwordEncoder()
        +filterChain(HttpSecurity)
        +corsConfigurationSource()
    }

    class DataInitializer {
        -UnitOfWork unitOfWork
        -PasswordEncoder passwordEncoder
        +run(String...)
        -initializeUsers()
        -initializeStudentGroups()
        -initializeSubjects()
        -initializeTeachersAndStudents()
        -initializeSampleGrades()
    }

    class SwaggerConfig {
        +openAPI()
        +customOpenAPI()
    }
}

' Entity Relationships
User ||--|| Student
User ||--|| Teacher
Student }o--|| StudentGroup
Teacher }o--o{ Subject
Student ||--o{ Grade
Teacher ||--o{ Grade
Subject ||--o{ Grade

' Controller to Service
UserController --> UserService
PublicController --> TeacherService
PublicController --> SubjectService
GradeController --> GradeService

' Service to UnitOfWork
UserService --> UnitOfWork
StudentService --> UnitOfWork
TeacherService --> UnitOfWork
SubjectService --> UnitOfWork
GradeService --> UnitOfWork

' UnitOfWork to Repositories
UnitOfWork --> UserRepository
UnitOfWork --> StudentRepository
UnitOfWork --> TeacherRepository
UnitOfWork --> SubjectRepository
UnitOfWork --> StudentGroupRepository
UnitOfWork --> GradeRepository

' Repository to Entities
UserRepository --> User
StudentRepository --> Student
TeacherRepository --> Teacher
SubjectRepository --> Subject
StudentGroupRepository --> StudentGroup
GradeRepository --> Grade

' Service to DTO transformations
UserService ..> UserDto
StudentService ..> StudentDto
TeacherService ..> TeacherDto
SubjectService ..> SubjectDto
GradeService ..> GradeDto

' Configuration dependencies
DataInitializer --> UnitOfWork
SecurityConfig ..> User

@enduml
